{
    "name": "nodejs-pulsar-example",
    "version": "0.1.0",
    "type": "module",
    "contributors": [
        {
            "name": "Gaël Reyrol",
            "email": "gael.reyrol@clever-cloud.com"
        }
    ],
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "start": "node src/index.js",
        "worker": "node src/worker.js",
        "build": "esbuild assets/app.js --bundle --outfile=dist/app.js && npx @tailwindcss/cli -i assets/app.css -o dist/app.css",
        "dev:js": "esbuild assets/app.js --bundle --watch --outfile=dist/app.js",
        "dev:css": "npx @tailwindcss/cli -i assets/app.css -o dist/app.css --watch"
    },
    "dependencies": {
        "cookie": "^1.1.1",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "morgan": "^1.10.1",
        "pulsar-client": "^1.16.0",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "uuid": "^13.0.0",
        "vader-sentiment": "^1.1.3"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.1",
        "@tailwindcss/forms": "^0.5.11",
        "esbuild": "^0.27.4",
        "tailwindcss": "^4.2.1"
    }
}
